# ─────────────────────────────────────────────────────────────────────────────
# BEDES MikroTik Controller — runtime configuration
#
# Copy this file to `.env` and adjust the values. The runtime values used by
# the container are sourced from `.env` via Docker Compose `env_file`.
# ─────────────────────────────────────────────────────────────────────────────

# Public hostname that Traefik will route to this service (required)
BEDES_DOMAIN=apehost.teelee.my.id

# Optional Basic Auth gate. Leave empty to disable. When both values are set,
# every request (except /api/health) must present `Authorization: Basic …`.
BEDES_ADMIN_USER=admin
BEDES_ADMIN_PASSWORD=change-this-password

# Docker network shared with Traefik + the docker-hosting-panel stack
PUBLIC_NETWORK=hosting-public

# CORS origin allowed by the Express server (must match the URL you open in
# the browser). Use https in production.
CORS_ORIGIN=https://apehost.teelee.my.id

# ─────────────────────────────────────────────────────────────────────────────
# LLM (AI assistant) — pick ONE provider
# ─────────────────────────────────────────────────────────────────────────────

# 'claude' | 'lmstudio' | 'cloudflare'
LLM_PROVIDER=lmstudio

# Claude (Anthropic) — highest quality, paid
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# LM Studio / any OpenAI-compatible endpoint — cheapest, runs locally
LMSTUDIO_ENDPOINT=https://llm.teelee.my.id/v1
LMSTUDIO_MODEL=qwen3-8b
LMSTUDIO_CONTEXT_WINDOW=70752

# Cloudflare Workers AI — cheap, function-calling support
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_AI_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct
# CLOUDFLARE_AI_GATEWAY=